# MongoDB connection string
DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# Resend API key for sending emails (contact form + magic link)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address for owner contact form notifications
NOTIFICATION_EMAIL=you@example.com

# Public app URL (used for CORS, referer validation, and BetterAuth baseURL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# BetterAuth secret — generate with: openssl rand -hex 32
# Required for signing sessions and encrypting auth state
BETTER_AUTH_SECRET=your-secret-here
