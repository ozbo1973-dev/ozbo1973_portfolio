{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Bash(**/.env)",
      "Read(**/.env)",
      "Write(**/.env)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "awaySummaryEnabled": false
}
